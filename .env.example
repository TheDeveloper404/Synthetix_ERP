# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=synthetix_db

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Authentication (REQUIRED - generate a secure random string)
JWT_SECRET=your-secure-random-string-min-32-chars-here

# LLM Provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Redis (optional - falls back to MongoDB for rate limiting)
REDIS_URL=

# Email notifications via Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Demo mode (set to false when OPENAI_API_KEY is configured)
DEMO_MODE=true

# Agent configuration
AGENT_PORT_BASE=3080
