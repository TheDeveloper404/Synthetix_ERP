# =============================================================
# Synthetix ERP — Environment Variables
# Copy to .env.local for local development
# =============================================================

# ─── Database ────────────────────────────────────────────────
# Local dev: plain MongoDB
MONGO_URL=mongodb://admin:password@localhost:27017/synthetix?authSource=admin
DB_NAME=synthetix

# Production (Azure Cosmos DB for MongoDB API — set by Bicep/CI)
# MONGO_URL=mongodb://synthetix:<primary-key>@synthetix-<hash>.mongo.cosmos.azure.com:10255/synthetix?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@synthetix-<hash>@

# ─── Application ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,http://localhost:3081

# ─── Authentication ──────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 48
JWT_SECRET=your-secure-random-string-min-32-chars-here

# ─── LLM Provider ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Redis ───────────────────────────────────────────────────
# Local dev (Docker Compose spins this up automatically)
REDIS_URL=redis://localhost:6379

# Production (Azure Cache for Redis — uses TLS on port 6380)
# REDIS_URL=rediss://:<primary-key>@synthetix-<hash>.redis.cache.windows.net:6380

# ─── Email ───────────────────────────────────────────────────
# Option 1: Azure Communication Services (production — takes priority)
ACS_CONNECTION_STRING=
ACS_FROM_EMAIL=DoNotReply@<your-managed-domain>.azurecomm.net

# Option 2: Resend (local dev / staging fallback)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ─── Azure Identity (production only) ────────────────────────
# When running in Azure Container Apps the managed identity is used automatically.
# Set these only if running outside ACA (e.g. local testing with a service principal).
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# Azure Key Vault URL (populated by Bicep in production)
AZURE_KEYVAULT_URL=

# ─── Demo / Feature flags ─────────────────────────────────────
# Set to false when OPENAI_API_KEY is configured and you want live AI
DEMO_MODE=true

# ─── Agent configuration ──────────────────────────────────────
AGENT_PORT_BASE=3082

# ─── Stripe (billing) ─────────────────────────────────────────
# Configurezi când ești ready pentru producție.
# Keys: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs — creează în Stripe Dashboard > Products > Add product
# Starter: $29/mo | Professional: $99/mo | Enterprise: $499/mo
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
